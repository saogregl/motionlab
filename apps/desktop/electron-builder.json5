/**
 * electron-builder configuration stub.
 * Will be fully configured during Epic 10 (Packaging).
 */
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.motionlab.desktop",
  "productName": "MotionLab",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-electron/**/*",
    "dist-react/**/*"
  ],
  "linux": {
    "target": ["AppImage"]
  },
  "mac": {
    "target": ["dmg"]
  },
  "win": {
    "target": ["nsis"]
  },
  // Native engine binary will be included as an extraResource in Epic 10
  "extraResources": []
}
