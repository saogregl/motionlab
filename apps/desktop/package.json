{
  "name": "@motionlab/desktop",
  "version": "0.0.1",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "build": "electron-forge make",
    "dev": "ELECTRON_DISABLE_SANDBOX=1 electron-forge start",
    "package": "electron-forge package",
    "clean": "rm -rf .vite dist dist-electron dist-react out *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "NODE_OPTIONS='--experimental-strip-types' eslint --flag unstable_native_nodejs_ts_config src/"
  },
  "dependencies": {
    "@motionlab/frontend": "workspace:*",
    "@motionlab/protocol": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^7.5.0",
    "@electron-forge/maker-rpm": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@electron-forge/plugin-vite": "^7.5.0",
    "@electron-forge/shared-types": "^7.5.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "electron": "^35.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.3",
    "vite": "^8.0.0"
  }
}
