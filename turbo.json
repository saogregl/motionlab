{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "out/**", ".vite/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["MOTIONLAB_LOG_LEVEL"]
    },
    "lint": {},
    "typecheck": {},
    "test": {
      "inputs": ["src/**", "**/*.test.ts"]
    },
    "clean": {
      "cache": false
    }
  }
}
