# Auto detect text files and perform LF normalization
* text=auto

# Force LF for source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.proto text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# C++ sources
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
