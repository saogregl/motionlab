{
  "name": "motionlab",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@motionlab/web",
    "dev:desktop": "ELECTRON_DISABLE_SANDBOX=1 turbo run dev --filter=@motionlab/desktop",
    "debug:agent": "pnpm --filter @motionlab/desktop run debug:agent",
    "lint": "biome check .",
    "lint:write": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "turbo run typecheck",
    "check": "biome check . && turbo run typecheck",
    "test": "turbo run test && pnpm run test:native",
    "test:native": "ctest --preset dev-mingw --test-dir native/engine",
    "docs:generate": "node scripts/repo-map/generate-repo-tree.mjs && node scripts/dependency-graph/generate-workspace-graph.mjs && node scripts/api-surface/generate-exports-report.mjs",
    "docs:check": "node scripts/docs-check/check-docs.mjs && node scripts/docs-check/run-markdownlint.mjs",
    "docs:prose": "vale docs readme.md plan.md",
    "prepare:agents": "pnpm docs:generate && pnpm docs:check",
    "clean": "turbo run clean && rm -rf node_modules",
    "bootstrap": "bash scripts/bootstrap.sh",
    "generate:proto": "node scripts/buf-generate.mjs",
    "generate:examples": "cmake --build native/engine/build/dev-linux --target generate-pendulum-example && native/engine/build/dev-linux/generate-pendulum-example apps/desktop/examples",
    "generate:templates": "cmake --build native/engine/build/dev-linux --target generate-templates && native/engine/build/dev-linux/generate-templates apps/desktop/resources/templates",
    "build:engine": "cmake --preset release-linux -S native/engine && cmake --build native/engine/build/release-linux --config Release && mkdir -p native/engine/build/release && cp native/engine/build/release-linux/motionlab-engine native/engine/build/release/",
    "build:engine:win": "cmake --preset release-mingw -S native/engine && cmake --build native/engine/build/release-mingw --config Release && mkdir -p native/engine/build/release && cp native/engine/build/release-mingw/motionlab-engine.exe native/engine/build/release/",
    "package:desktop": "pnpm run build:engine && pnpm --filter @motionlab/desktop run package",
    "lint:proto": "buf lint",
    "breaking:proto": "buf breaking --against '.git#branch=main'"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@bufbuild/buf": "^1.47.0",
    "@bufbuild/protoc-gen-es": "^2.0.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.0",
    "markdownlint-cli2": "^0.18.1",
    "turbo": "^2.8.16",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf",
      "electron",
      "esbuild"
    ],
    "overrides": {
      "three-mesh-bvh": "^0.9.9"
    }
  }
}
