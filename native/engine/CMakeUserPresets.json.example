{
  "version": 6,
  "configurePresets": [
    {
      "name": "mingw-local",
      "inherits": "mingw-base",
      "hidden": true,
      "description": "Override compiler paths when MSYS2 is not on PATH",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "C:/msys64/mingw64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/msys64/mingw64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "C:/msys64/mingw64/bin/ninja.exe"
      }
    },
    {
      "name": "dev-mingw",
      "inherits": "mingw-local",
      "binaryDir": "${sourceDir}/build/dev-mingw",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTS": "ON"
      }
    }
  ]
}
