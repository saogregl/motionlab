{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "clientKind": "git",
    "defaultBranch": "main",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!packages/protocol/src/generated",
      "!native/engine/src/generated",
      "!.turbo",
      "!native/engine/build",
      "!**/storybook-static",
      "!**/dist",
      "!**/dist-electron",
      "!**/dist-react",
      "!**/.vite",
      "!**/occt-wasm"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "indentWidth": 2,
      "lineWidth": 100
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off"
      },
      "correctness": {
        // Pre-existing violations tracked as follow-up; downgraded so CI can gate on new issues.
        "useExhaustiveDependencies": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "useIterableCallbackReturn": "warn",
        "noArrayIndexKey": "warn"
      },
      "style": {
        "useImportType": "off"
      },
      "a11y": {
        "useAltText": "off",
        "useButtonType": "off",
        "useSemanticElements": "off",
        "useKeyWithClickEvents": "off",
        "noLabelWithoutControl": "warn",
        "noStaticElementInteractions": "warn",
        "useValidAriaRole": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "json": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100
    }
  }
}
