{
  "typescript.tsdk": "node_modules/typescript/lib",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit"
  },
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.tabSize": 4
  },
  "[cmake]": {
    "editor.tabSize": 2
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.turbo": true,
    "native/engine/build": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true
  },
  "cmake.sourceDirectory": "${workspaceFolder}/native/engine",
  "cmake.buildDirectory": "${workspaceFolder}/native/engine/build/dev"
}
